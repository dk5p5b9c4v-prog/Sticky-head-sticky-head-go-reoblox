local offsetValue = 1.8

local function updateSlider(val)
    offsetValue = math.clamp(val, 0.5, 5)
    local percent = (offsetValue - 0.5) / 4.5
    sliderBar.Size = UDim2.new(percent, 0, 1, 0)
    
    local sliderAbsSize = offsetSlider.AbsoluteSize.X
    local knobX = percent * sliderAbsSize - 9
    knob.Position = UDim2.new(0, knobX, 0.5, -9)
    
    offsetLabel.Text = string.format("Hand Offset: %.1f studs", offsetValue)
end

local function handleSliderDrag()
    local conn = UserInputService.InputChanged:Connect(function(move)
        if move.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = (move.Position.X - offsetSlider.AbsolutePosition.X) / offsetSlider.AbsoluteSize.X
            updateSlider(0.5 + rel * 4.5)
        end
    end)
    local release = UserInputService.InputEnded:Connect(function(endInput)
        if endInput.UserInputType == Enum.UserInputType.MouseButton1 then
            conn:Disconnect()
            release:Disconnect()
        end
    end)
end

offsetSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        handleSliderDrag()
    end
end)

updateSlider(1.8)

-- Functions (unchanged)
local function getBall()
    local ball = workspace:FindFirstChild("Football") or workspace:FindFirstChild("Ball") or workspace:FindFirstChild("TheDuke")
    if not ball then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:lower():find("ball") or obj.Name:lower():find("football") or obj.Name:lower():find("duke")) then
                return obj
            end
        end
    end
    return ball
end

local function getHand()
    local character = player.Character
    if not character then return nil end
    return character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")
end

local function teleportBallToHand()
    if not scriptEnabled then return end
    local hand = getHand()
    local ball = getBall()
    if hand and ball and ball:IsA("BasePart") then
        ball.CFrame = hand.CFrame * CFrame.new(0, 0, -offsetValue)
        ball.AssemblyLinearVelocity = Vector3.new(0,0,0)
        ball.AssemblyAngularVelocity = Vector3.new(0,0,0)
        if ball.SetNetworkOwner then ball:SetNetworkOwner(player) end
    end
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not scriptEnabled then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        teleportBallToHand()
    end
end)

local function startManipulation()
    stopManipulation()
    magnetConnection = RunService.Heartbeat:Connect(function()
        if not scriptEnabled or not magnetEnabled then return end
        local hand = getHand()
        local ball = getBall()
        if not hand or not ball or not ball:IsA("BasePart") then return end
        
        local targetPos = hand.Position + hand.CFrame.LookVector * -offsetValue
        local direction = (targetPos - ball.Position)
        local distance = direction.Magnitude
        
        local pullStrength = distance > 8 and 45 or 75
        local force = direction.Unit * math.min(distance * pullStrength, 350)
        
        ball.AssemblyLinearVelocity = ball.AssemblyLinearVelocity:Lerp(force, 0.6)
        ball.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        if ball.SetNetworkOwner then ball:SetNetworkOwner(player) end
    end)
end

local function stopManipulation()
    if magnetConnection then magnetConnection:Disconnect() magnetConnection = nil end
end

