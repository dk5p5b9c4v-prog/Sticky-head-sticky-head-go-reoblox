local function getBall()
    local ball = workspace:FindFirstChild("Football") or workspace:FindFirstChild("Ball")
    if not ball then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:lower():find("ball") or obj.Name:lower():find("football")) then
                return obj
            end
        end
    end
    return ball
end

local function getHand()
    local character = player.Character
    if not character then return nil end
    return currentHandSide == "Right" 
        and (character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm"))
        or  (character:FindFirstChild("LeftHand") or character:FindFirstChild("Left Arm"))
end

local function teleportBallToHand()
    local hand = getHand()
    local ball = getBall()
    if hand and ball and ball:IsA("BasePart") then
        ball.CFrame = hand.CFrame * CFrame.new(0, 0, -offsetValue)
        ball.AssemblyLinearVelocity = Vector3.new(0,0,0)
        ball.AssemblyAngularVelocity = Vector3.new(0,0,0)
        if ball.SetNetworkOwner then ball:SetNetworkOwner(player) end
        print("Ball caught to " .. currentHandSide .. " hand!")
    end
end

tpBtn.MouseButton1Click:Connect(teleportBallToHand)

-- Quick Catch on Left Mouse Click
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        teleportBallToHand()
    end
end)

-- Enhanced Manipulation
local function startManipulation()
    stopManipulation()
    magnetConnection = RunService.Heartbeat:Connect(function()
        if not magnetEnabled then return end
        
        local hand = getHand()
        local ball = getBall()
        local character = player.Character
        if not hand or not ball or not ball:IsA("BasePart") or not character then return end
        
        local targetPos = hand.Position + hand.CFrame.LookVector * -offsetValue
        local direction = (targetPos - ball.Position)
        local distance = direction.Magnitude
        
        local pullStrength = distance > 8 and 45 or 75
        local force = direction.Unit * math.min(distance * pullStrength, 350)
        
        ball.AssemblyLinearVelocity = ball.AssemblyLinearVelocity:Lerp(force, 0.6)
        ball.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        if ball.SetNetworkOwner then ball:SetNetworkOwner(player) end
    end)
end

local function stopManipulation()
    if magnetConnection then
        magnetConnection:Disconnect()
        magnetConnection = nil
    end
end

findBtn.MouseButton1Click:Connect(function()
    local ball = getBall()
    if ball then
        local orig = ball.Color
        ball.Color = Color3.fromRGB(0, 255, 100)
        task.wait(0.6)
        ball.Color = orig
    end
end)

dropBtn.MouseButton1Click:Connect(function()
    local ball = getBall()
    if ball then
        ball.AssemblyLinearVelocity = Vector3.new(0, -20, 0)
        if ball.SetNetworkOwner then ball:SetNetworkOwner(nil) end
    end
end)

