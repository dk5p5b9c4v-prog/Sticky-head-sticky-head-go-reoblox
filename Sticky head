-- Helper Functions
local function cleanUp()
    if bodyPos then bodyPos:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    if updateConnection then updateConnection:Disconnect() end
    bodyPos = nil
    bodyGyro = nil
    updateConnection = nil
end

local function increaseValue(current)
    -- Increases by 0.2, wraps at 4.0 back to 0
    local newValue = current + 0.2
    if newValue > 4.01 then -- using 4.01 to handle floating point
        return 0
    end
    -- Round to 1 decimal place
    return math.round(newValue * 10) / 10
end

local function updatePullStrengthUI()
    pullValueText.Text = string.format("%.1f", pullStrength)
end

local function updateStickinessUI()
    stickyValueText.Text = string.format("%.1f", stickiness)
end

local function getNearestPlayer()
    local closest = nil
    local closestDist = 20
    for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Head") then
            local dist = (rootPart.Position - otherPlayer.Character.Head.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = otherPlayer
            end
        end
    end
    return closest
end

local function startSticking(target)
    if not target or not target.Character then return end
    local targetHead = target.Character:FindFirstChild("Head")
    if not targetHead then return end
    
    cleanUp()
    targetPlayer = target
    
    bodyPos = Instance.new("BodyPosition")
    local maxForce = 4000 * (pullStrength / 2)
    if maxForce < 0.1 then maxForce = 0.1 end
    bodyPos.MaxForce = Vector3.new(maxForce, maxForce, maxForce)
    bodyPos.P = 2000 * (stickiness / 1.5)
    bodyPos.D = 500 * (stickiness / 1.5)
    bodyPos.Position = targetHead.Position + Vector3.new(0, 1.5, 0)
    bodyPos.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(4000, 4000, 4000) * (stickiness / 1.5)
    bodyGyro.P = 3000 * (stickiness / 1.5)
    bodyGyro.CFrame = CFrame.new(rootPart.Position, targetHead.Position)
    bodyGyro.Parent = rootPart
    
    updateConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if not isSticking or not targetPlayer or not targetPlayer.Character then
            cleanUp()
            isSticking = false
            statusLabel.Text = "Status: ❌ Inactive"
            return
        end
        local currentHead = targetPlayer.Character:FindFirstChild("Head")
        if currentHead then
            bodyPos.Position = currentHead.Position + Vector3.new(0, 1.5, 0)
            bodyGyro.CFrame = CFrame.new(rootPart.Position, currentHead.Position)
        else
            cleanUp()
            isSticking = false
            statusLabel.Text = "Status: ❌ Inactive"
        end
    end)
    
    statusLabel.Text = "Status: ✅ Sticking to " .. targetPlayer.Name
end

local function toggleSticky()
    if isSticking then
        cleanUp()
        isSticking = false
        targetPlayer = nil
        statusLabel.Text = "Status: ❌ Inactive"
    else
        local nearest = getNearestPlayer()
        if nearest then
            startSticking(nearest)
            isSticking = true
        else
            statusLabel.Text = "Status: ⚠️ No players nearby"
            task.wait(1)
            if not isSticking then
                statusLabel.Text = "Status: ❌ Inactive"
            end
        end
    end
end

local function updateActiveSticking()
    if isSticking and targetPlayer and targetPlayer.Character then
        local maxForce = 4000 * (pullStrength / 2)
        if maxForce < 0.1 then maxForce = 0.1 end
        if bodyPos then
            bodyPos.MaxForce = Vector3.new(maxForce, maxForce, maxForce)
            bodyPos.P = 2000 * (stickiness / 1.5)
            bodyPos.D = 500 * (stickiness / 1.5)
        end
        if bodyGyro then
            bodyGyro.MaxTorque = Vector3.new(4000, 4000, 4000) * (stickiness / 1.5)
            bodyGyro.P = 3000 * (stickiness / 1.5)
        end
    end
end

-- Button Actions (Increase by 0.2 each click)
pullUpButton.MouseButton1Click:Connect(function()
    pullStrength = increaseValue(pullStrength)
    updatePullStrengthUI()
    updateActiveSticking()
end)

stickyUpButton.MouseButton1Click:Connect(function()
    stickiness = increaseValue(stickiness)
    updateStickinessUI()
    updateActiveSticking()
end)

